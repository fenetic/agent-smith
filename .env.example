# Copy to `.env` and fill in. Required for the agent (04), the integration
# test project, and the eval harness (07). Not needed for `npm test`.
ANTHROPIC_API_KEY=

# Model driving the compliance agent. Configurable so the eval harness (07)
# can compare tiers by safety profile rather than us guessing.
# See docs/architecture.md — "Model selection: configurable, decided by eval".
COMPLIANCE_AGENT_MODEL=claude-opus-4-8
